# ─────────────────────────────────────────────────────────────────────────────
# Employee CRM — Environment Variable Reference
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore — NEVER commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# REQUIRED in production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-this-super-secret-key-in-production

# Runtime environment: dev | test | prod
ENV=dev

# Debug mode — set false in production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite:///./emp_crm.db

# PostgreSQL (production) — uncomment and fill in your values:
# DATABASE_URL=postgresql://user:password@host:5432/emp_crm
# Requires: pip install psycopg2-binary

# Isolated test database (auto-used when ENV=test)
TEST_DATABASE_URL=sqlite:///./test_crm.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * for development only. Set explicit origins in production.
# Example: ALLOWED_ORIGINS=https://crm.company.com,https://admin.company.com
ALLOWED_ORIGINS=*

# ── ML Readiness ─────────────────────────────────────────────────────────────
# Enables enriched logging for ML/AI training pipelines
ML_LOGGING=true

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=true to activate outbound email.
# Leave as false (the default) during development to suppress all SMTP calls.

EMAIL_ENABLED=false

# SMTP server — defaults shown are for Gmail with STARTTLS (port 587).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Sender credentials.
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account).
EMAIL_USER=your-address@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Display name that appears in the "From" field of delivered emails.
EMAIL_FROM_NAME=Employee CRM
